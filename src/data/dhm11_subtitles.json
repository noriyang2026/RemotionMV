[
    {
        "start": 0,
        "end": 3,
        "text": "記録ログ 第11話 抜粋開始。"
    },
    {
        "start": 3,
        "end": 5,
        "text": "ポットリミット オマハ。"
    },
    {
        "start": 5,
        "end": 8,
        "text": "手札は4枚。"
    },
    {
        "start": 8,
        "end": 10,
        "text": "可能性は増え、視界は濁る。"
    },
    {
        "start": 10,
        "end": 13,
        "text": "ようこそ、記録の片隅へ。"
    },
    {
        "start": 13,
        "end": 18,
        "text": "このログ、開始時点と終了時点で 微細なコードさえが変化している。"
    },
    {
        "start": 18,
        "end": 21,
        "text": "これ、あなたが勝ったはずの記録なのに。"
    },
    {
        "start": 21,
        "end": 25,
        "text": "まさか、また観察で俺の価値を決めるのかよ。"
    },
    {
        "start": 25,
        "end": 28,
        "text": "あれを信じてたのか、シャルロット。"
    },
    {
        "start": 28,
        "end": 32,
        "text": "片目だからこそ、見えるものもあるのよ。"
    },
    {
        "start": 32,
        "end": 36,
        "text": "この記録、誰かが手を加えてる。"
    },
    {
        "start": 36,
        "end": 38,
        "text": "AIの自動保管じゃない。"
    },
    {
        "start": 38,
        "end": 43,
        "text": "女王の記録は一度焼かれた。"
    },
    {
        "start": 43,
        "end": 47,
        "text": "でも、その灰から君が立ち上がったんだ。"
    },
    {
        "start": 47,
        "end": 50,
        "text": "おい、ジャック。お前、何を知ってる？"
    },
    {
        "start": 50,
        "end": 53,
        "text": "片目じゃ全部は見えない。"
    },
    {
        "start": 53,
        "end": 57,
        "text": "でも、真実の輪郭くらいは見..."
    },
    {
        "start": 57,
        "end": 65,
        "text": "女王の記録が今再び始まろうとしていた。"
    },
    {
        "start": 77,
        "end": 81,
        "text": "Fading lights, a silent room."
    }
